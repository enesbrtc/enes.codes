          {/* Identity & Context */}
          <div className="flex-1 min-w-0">
            <h1 className="text-2xl font-semibold text-foreground">Enes Barutcu</h1>
            <p className="text-sm text-muted-foreground">Application Support Engineer</p>
            
            {/* Focus Tags */}
            <div className="flex flex-wrap gap-2 mt-2">
